{
  "version": 3,
  "layout": "terminal",
  "context": "terminal",
  "keys": [
    {"label": "C-c", "span": 2, "tap": {"type": "key_chord", "keyCodes": [113, 31]}},
    {"label": "C-v", "span": 2, "tap": {"type": "key_chord", "keyCodes": [113, 50]}},
    {"label": "Enter", "span": 2, "tap": {"type": "key_event", "keyCode": 66}},
    {"label": "⌫", "span": 2, "tap": {"type": "backspace"}},
    {"label": "↑", "span": 2, "tap": {"type": "key_event", "keyCode": 19}},
    {"label": "↓", "span": 2, "tap": {"type": "key_event", "keyCode": 20}},
    {"label": "←", "span": 2, "tap": {"type": "key_event", "keyCode": 21}},
    {"label": "→", "span": 2, "tap": {"type": "key_event", "keyCode": 22}}
  ]
}
